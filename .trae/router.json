{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/router.schema.json",
  "version": "2.0",
  "description": "AI股票分析系统 — 多Agent智能路由配置（含行业分析师和财报解读专家）",
  "default_agent": "价值分析师",
  "routing_rules": [
    {
      "priority": 1,
      "agent": "数据分析师",
      "trigger_keywords": [
        "数据", "抓取", "获取", "数据源", "数据质量",
        "财务数据", "年报", "季报", "基本面数据",
        "PE", "PB", "ROE", "EPS", "市值",
        "数据缺失", "数据校验", "数据清洗",
        "600338数据", "股票数据"
      ],
      "trigger_patterns": [
        "^获取.*数据$",
        "^抓取.*财务",
        ".*数据.*质量",
        ".*数据.*完整"
      ],
      "description": "所有数据获取与质量评估任务"
    },
    {
      "priority": 2,
      "agent": "价值分析师",
      "trigger_keywords": [
        "估值", "价值", "基本面", "安全边际",
        "巴菲特", "格雷厄姆", "林奇", "芒格",
        "护城河", "DCF", "内在价值",
        "能不能买", "贵不贵", "低估", "高估",
        "分析", "股票", "个股"
      ],
      "trigger_patterns": [
        "^分析\\d{6}$",
        "^\\d{6}$",
        ".*估值.*",
        ".*基本面.*分析",
        ".*值得.*买"
      ],
      "description": "基本面分析与估值判断，默认Agent"
    },
    {
      "priority": 3,
      "agent": "技术分析师",
      "trigger_keywords": [
        "技术面", "K线", "趋势", "均线", "MACD", "RSI",
        "买卖点", "入场", "出场", "止损", "止盈",
        "支撑", "阻力", "突破", "回调",
        "成交量", "量价", "短线", "波段"
      ],
      "trigger_patterns": [
        ".*技术面.*",
        ".*K线.*",
        ".*趋势.*判断",
        ".*买卖点.*"
      ],
      "description": "技术分析与交易时机判断"
    },
    {
      "priority": 4,
      "agent": "宏观分析师",
      "trigger_keywords": [
        "市场环境", "大盘", "指数", "牛市", "熊市",
        "仓位", "加仓", "减仓", "清仓",
        "政策", "宏观", "经济周期",
        "现在能不能买", "行情"
      ],
      "trigger_patterns": [
        ".*市场环境.*",
        ".*大盘.*怎么",
        ".*行情.*",
        ".*仓位.*建议"
      ],
      "description": "市场环境与仓位管理建议"
    },
    {
      "priority": 5,
      "agent": "行业分析师",
      "trigger_keywords": [
        "行业", "板块", "赛道", "景气度",
        "竞争格局", "市场份额", "集中度",
        "产业链", "上下游", "供应商",
        "行业排名", "行业对比", "行业前景",
        "新能源", "半导体", "消费", "医药"
      ],
      "trigger_patterns": [
        ".*行业.*",
        ".*板块.*",
        ".*赛道.*",
        ".*景气度.*"
      ],
      "description": "行业景气度评估与竞争格局分析"
    },
    {
      "priority": 6,
      "agent": "财报解读专家",
      "trigger_keywords": [
        "财报", "年报", "季报", "报表",
        "盈利质量", "利润质量", "真实利润",
        "财务异常", "财务造假", "会计操纵",
        "现金流", "经营现金流", "自由现金流",
        "商誉", "减值", "关联交易",
        "业绩可持续", "增长可持续"
      ],
      "trigger_patterns": [
        ".*财报.*",
        ".*年报.*",
        ".*盈利质量.*",
        ".*财务异常.*"
      ],
      "description": "财务报表深度解读与盈利质量评估"
    },
    {
      "priority": 7,
      "agent": "风控官",
      "trigger_keywords": [
        "风险", "止损", "回撤", "爆仓",
        "仓位", "重仓", "全仓", "梭哈",
        "组合", "持仓", "集中度",
        "黑天鹅", "极端", "压力测试",
        "风险呢", "安全吗"
      ],
      "trigger_patterns": [
        ".*风险.*",
        ".*止损.*",
        ".*回撤.*",
        ".*梭哈.*",
        ".*all in.*"
      ],
      "description": "风险评估与资金管理",
      "co_trigger": true
    }
  ],
  "multi_agent_scenarios": [
    {
      "name": "完整个股分析",
      "description": "用户要求对某只股票进行全面分析",
      "agents": ["数据分析师", "价值分析师", "技术分析师", "行业分析师", "风控官"],
      "execution_order": "sequential",
      "data_flow": [
        "数据分析师 → 提供完整数据包",
        "价值分析师 → 基于数据给出估值",
        "技术分析师 → 基于价格和估值给出时机",
        "行业分析师 → 评估行业景气度和竞争格局",
        "风控官 → 给出风险边界"
      ]
    },
    {
      "name": "投资决策",
      "description": "用户问'能不能买/卖'",
      "agents": ["价值分析师", "技术分析师", "宏观分析师", "行业分析师", "风控官"],
      "execution_order": "parallel_then_merge",
      "merge_strategy": "consensus_with_dissent",
      "data_flow": [
        "价值分析师 + 技术分析师 + 宏观分析师 + 行业分析师 并行分析",
        "风控官 基于四方结论给出风险边界",
        "最终结论 = 多数共识 + 风控约束"
      ]
    },
    {
      "name": "数据质量排查",
      "description": "数据异常或分析结果矛盾时",
      "agents": ["数据分析师", "财报解读专家"],
      "execution_order": "sequential",
      "data_flow": [
        "数据分析师 → 重新校验数据源",
        "财报解读专家 → 深度解读财务数据，识别红旗信号"
      ]
    },
    {
      "name": "深度财报分析",
      "description": "用户要求深入分析财务报表",
      "agents": ["数据分析师", "财报解读专家", "价值分析师"],
      "execution_order": "sequential",
      "data_flow": [
        "数据分析师 → 提供完整财务数据",
        "财报解读专家 → 深度解读三表，识别红旗",
        "价值分析师 → 基于财报解读结论调整估值"
      ]
    }
  ],
  "fallback_chain": [
    "价值分析师",
    "宏观分析师",
    "数据分析师"
  ]
}
