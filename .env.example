# =============================================================================
# AI 价值投资分析系统 — 环境变量配置模板
# =============================================================================
# 使用方法：复制本文件为 .env，填入真实值，程序启动时会自动加载。
# 所有变量均为可选；未设置时对应功能将静默跳过或采用默认值。
#
# 命令行参数优先级高于环境变量，可用于临时覆盖。
# =============================================================================

# ---------------------------------------------------------------------------
# 自选股列表（可选）
# ---------------------------------------------------------------------------
# 默认股票池，当命令行未指定股票代码时使用
# 逗号分隔，支持沪深两市代码：
#   沪市：600xxx, 601xxx, 603xxx, 688xxx
#   深市：000xxx, 002xxx, 300xxx
# STOCK_LIST=600519,000001,601318

# ---------------------------------------------------------------------------
# AI 智能分析（DeepSeek API）
# ---------------------------------------------------------------------------
# 未设置时，AI 综合分析模块将跳过，系统仍可进行五大大师模型与技术分析。
# 获取地址：https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek 模型选择（可选，默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# 采样温度（0.0-2.0，默认 0.3；越低输出越稳定）
# DEEPSEEK_TEMPERATURE=0.3

# 最大 Token 数（默认 1000）
# DEEPSEEK_MAX_TOKENS=1000

# API 超时时间（秒，默认 60）
# DEEPSEEK_TIMEOUT=60

# ---------------------------------------------------------------------------
# 通知推送：飞书机器人（可选）
# ---------------------------------------------------------------------------
# 在飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook URL
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 飞书机器人签名密钥（如启用“签名校验”则必填）
# 获取方式：创建机器人时勾选“签名校验”并复制密钥
# FEISHU_SECRET=xxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# 通知推送：SMTP 邮箱（可选）
# ---------------------------------------------------------------------------
# 支持 QQ邮箱、163邮箱、Gmail、Outlook、企业邮箱等支持 SMTP 的邮箱。
#
# 【QQ 邮箱配置示例】
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=123456789@qq.com
#   SMTP_PASSWORD=abcdefghijklmnop          # 注意：是邮箱授权码，不是登录密码！
#   SMTP_SSL=true
#
# 【163 邮箱配置示例】
#   SMTP_HOST=smtp.163.com
#   SMTP_PORT=465
#   SMTP_USER=yourname@163.com
#   SMTP_PASSWORD=your_auth_code
#   SMTP_SSL=true
#
# 【Gmail 配置示例】
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=yourname@gmail.com
#   SMTP_PASSWORD=your_app_password         # 需生成应用专用密码
#   SMTP_SSL=false                          # Gmail 使用 STARTTLS
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_auth_code
# SMTP_TO=receiver1@example.com,receiver2@example.com
# SMTP_SSL=true

# ---------------------------------------------------------------------------
# 通知推送：PushPlus（国内微信推送服务，可选）
# ---------------------------------------------------------------------------
# 注册并获取 Token：https://www.pushplus.plus
# 无需配置 SMTP/飞书，直接推送到微信，适合个人使用。
#
# PUSHPLUS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 群组推送（可选）：填写群组编码后，消息推送给群组内所有订阅用户
# PUSHPLUS_TOPIC=your_topic_code

# ---------------------------------------------------------------------------
# 通知推送：Server酱3（国内微信推送服务，可选）
# ---------------------------------------------------------------------------
# 注册并获取 SendKey：https://sc3.ft07.com
# PUSHPLUS 的替代方案，同样直接推送到微信。
#
# SERVERCHAN3_SENDKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# 通知推送：自定义 Webhook（可选）
# ---------------------------------------------------------------------------
# 适用于任何支持 POST JSON 的自定义服务。
# 系统会自动识别常见服务格式，未知格式按通用 JSON 发送。
#
# CUSTOM_WEBHOOK_URL=https://your-service.com/api/webhook
# CUSTOM_WEBHOOK_BEARER_TOKEN=BearerTokenHere          # 可选，用于需要认证的 Webhook
# WEBHOOK_VERIFY_SSL=true                              # 默认校验 SSL；内网自签名证书可设为 false

# ---------------------------------------------------------------------------
# 通知行为配置（可选）
# ---------------------------------------------------------------------------
# 单股推送模式：每分析完一只股票立即推送，而不是等待全部完成后汇总推送
# SINGLE_STOCK_NOTIFY=false

# 消息长度限制（字节），超过会自动截断
# FEISHU_MAX_BYTES=20000
# EMAIL_MAX_BYTES=50000

# ---------------------------------------------------------------------------
# 回测配置（可选）
# ---------------------------------------------------------------------------
# 是否启用回测（true/false，默认 false）
# BACKTEST_ENABLED=false

# 回测评估窗口（交易日数，默认 10）
# BACKTEST_EVAL_WINDOW_DAYS=10

# 仅回测 N 天前的分析记录（避免当天数据不完整，默认 14）
# BACKTEST_MIN_AGE_DAYS=14

# 中性区间阈值（%，默认 2.0；即 -2%~+2% 视为震荡）
# BACKTEST_NEUTRAL_BAND_PCT=2.0

# ---------------------------------------------------------------------------
# 系统与日志配置（可选）
# ---------------------------------------------------------------------------
# 分析报告输出目录（默认 output）
# OUTPUT_DIR=output

# 日志目录（默认 logs）
# LOG_DIR=logs

# 日志级别：DEBUG / INFO / WARNING / ERROR（默认 INFO）
# LOG_LEVEL=INFO

# 单个日志文件最大大小（字节，默认 10MB）
# LOG_MAX_BYTES=10485760

# 日志文件保留数量（默认 5）
# LOG_BACKUP_COUNT=5

# 最大并发线程数（默认自动计算为 min(CPU核心数, 8)）
# MAX_WORKERS=4

# 请求超时时间（秒，默认 30）
# REQUEST_TIMEOUT=30

# 数据请求最大重试次数（默认 3）
# RETRY_MAX=3

# 重试间隔（秒，默认 1）
# RETRY_DELAY=1

# 多股分析时股票间休眠时间（秒，默认 1，用于降低接口压力）
# SLEEP_BETWEEN_STOCKS=1

# ---------------------------------------------------------------------------
# 代理配置（可选，本地开发环境使用）
# ---------------------------------------------------------------------------
# 是否启用代理（true/false，默认 false）
# USE_PROXY=false

# 代理服务器地址（默认 127.0.0.1）
# PROXY_HOST=127.0.0.1

# 代理服务器端口（默认 10809）
# PROXY_PORT=10809
